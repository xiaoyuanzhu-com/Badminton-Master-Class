{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "person.schema.json",
  "title": "Person",
  "description": "An author or content creator. File: people/{slug}.json",
  "type": "object",
  "required": ["name"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Display name of the person"
    },
    "bio": {
      "type": "string",
      "description": "Short biography"
    },
    "platforms": {
      "type": "object",
      "description": "Platform profile URLs keyed by platform name",
      "additionalProperties": {
        "type": "string",
        "format": "uri"
      }
    }
  }
}
