{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "path.schema.json",
  "title": "Learning Path",
  "description": "A curated, ordered sequence of content items for structured learning (e.g., 'Beginner 30-Day Plan').",
  "type": "object",
  "required": ["title", "summary", "difficulty", "steps"],
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Path name, e.g., '新手30天入门计划'"
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "What you'll learn in this path"
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced"],
      "description": "Overall difficulty level"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "description": "Ordered list of learning steps",
      "items": {
        "type": "object",
        "required": ["title", "content_slugs"],
        "additionalProperties": false,
        "properties": {
          "day": {
            "type": "integer",
            "minimum": 1,
            "description": "Day number for daily plans"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "description": "Step title, e.g., '握拍基础'"
          },
          "note": {
            "type": "string",
            "description": "Editorial note for this step"
          },
          "content_slugs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9-]+$"
            },
            "description": "References to content file slugs (filename without extension)"
          }
        }
      }
    }
  }
}
