{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "content.schema.json",
  "title": "Content",
  "description": "A tutorial or video content item. Lives alongside its technique's _technique.json.",
  "type": "object",
  "required": ["title", "source_url", "source_platform"],
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Title of the content"
    },
    "summary": {
      "type": "string",
      "description": "Brief description of the content"
    },
    "source_url": {
      "type": "string",
      "format": "uri",
      "description": "URL to the original content"
    },
    "source_platform": {
      "type": "string",
      "enum": ["bilibili", "xiaohongshu", "douyin", "wechat", "youtube", "other"],
      "description": "Platform where the content is hosted"
    },
    "person": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Slug reference to a file in people/"
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced"],
      "description": "Difficulty level"
    },
    "duration": {
      "type": "string",
      "pattern": "^[0-9]+:[0-9]{2}$",
      "description": "Duration in M:SS or MM:SS format"
    },
    "editor_notes": {
      "type": "string",
      "description": "Editorial notes about why this content is included"
    }
  }
}
